# ── ProcessAuth AI Humanizer — API Keys Template ──────────────────────────────
# Copy this file to .env and fill in your actual keys.
# The .env file is git-ignored and will NEVER be committed to GitHub.

# Google Gemini API Key (from Google AI Studio → https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# API Ninjas Key (from https://api-ninjas.com/profile)
NINJA_API_KEY=your_ninja_api_key_here
